# Copy to .env and fill in ONE provider. The teacher client auto-detects which is set.
# Priority order if multiple are set: OPENAI_API_KEY (custom) > OPENROUTER > GROQ > GEMINI.

# --- Option A: Google Gemini (free tier, recommended for "free") ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Option B: OpenRouter (has free models) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# --- Option C: Groq (free tier, fast) ---
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option D: Any OpenAI-compatible endpoint (paid credits / custom) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Hugging Face (for pushing model + dataset). Needed only at ship time.
HF_TOKEN=
HF_USERNAME=
